# Copy to .env and fill in from Supabase → Project Settings → API
# Save the file, then restart: npm run dev

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either key from the dashboard (both work):
# - Legacy "anon" key (starts with eyJ...)
# - New "publishable" key (starts with sb_publishable_...)
VITE_SUPABASE_ANON_KEY=your_key_here
